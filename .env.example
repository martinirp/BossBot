# Configurações do BossBot
# Defina SPAM_COUNT=0 para desativar as notificações via DM (privado)
SPAM_COUNT=0
SPAM_INTERVAL_MS=3000
SUBSCRIBER_INTERVAL_MS=2000
POLL_EXPIRY_SECONDS=300

# Configurações de Mundo e Admin
TIBIA_WORLD=Quelibra
BOT_OWNER_NUMBER=5511999999999

# Notificações em Grupos e Comunidades
ENABLE_GROUP_MENTIONS=true
ENABLE_COMMUNITY_ALERTS=true

# Limite de grupos em que o bot pode ser vinculado
# Use o comando !addgroup dentro de um grupo para vinculá-lo.
MAX_ALLOWED_GROUPS=3

# Nome do arquivo de banco de dados
DB_FILE=bossbot.db

# Chaves da API do Pushover (opcional)
# PUSHOVER_TOKEN: Token da aplicação criada no Pushover
# PUSHOVER_USER_KEY: User key global para receber todos os alertas (opcional)
PUSHOVER_TOKEN=af1fh3ytimukmykxn1eyqt2ajrcdiu

PUSHOVER_USER_KEY=seu_user_key_aqui

# Tempo de repetição do alerta (Emergência) em segundos (mínimo 30)
PUSHOVER_RETRY=30

# Som customizado do alerta (Padrão: siren)
PUSHOVER_SOUND=alien
